# Supabase client auth
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Canonical site URL used for metadata, auth redirects, and public beta copy.
# Production should always set this to the real public domain.
NEXT_PUBLIC_SITE_URL=

# Public beta support channel surfaced in footer, legal pages, and auth flows.
NEXT_PUBLIC_SUPPORT_EMAIL=support@riskopslab.com

# Amplitude browser API key for client-side product analytics and replay.
NEXT_PUBLIC_AMPLITUDE_API_KEY=
# Optional: enable Amplitude while running local development on localhost.
NEXT_PUBLIC_ENABLE_AMPLITUDE_DEV=false

# Public captcha key for signup and password recovery.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# Public growth / SEO foundation.
NEXT_PUBLIC_GTM_ID=
NEXT_PUBLIC_SILKTIDE_CSS_URL=
NEXT_PUBLIC_SILKTIDE_JS_URL=
NEXT_PUBLIC_SILKTIDE_CONFIG_JSON=
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
NEXT_PUBLIC_BING_SITE_VERIFICATION=
INDEXNOW_KEY=

# Product email notifications via Resend. Supabase Auth emails stay on Supabase.
RESEND_API_KEY=
EMAIL_FROM_ADDRESS=
EMAIL_FROM_NAME=
EMAIL_REPLY_TO_ADDRESS=

# Sentry client DSN for browser errors, tracing, and session replay.
NEXT_PUBLIC_SENTRY_DSN=

# Optional server/edge DSN. If omitted, server runtimes fall back to NEXT_PUBLIC_SENTRY_DSN.
SENTRY_DSN=

# Source map upload and build-time Sentry integration.
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_ENVIRONMENT=

# Supabase Auth captcha secret used by supabase/config.toml for local stacks.
SUPABASE_AUTH_TURNSTILE_SECRET=
